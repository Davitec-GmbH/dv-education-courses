{
    "name": "davitec/dv-education-courses",
    "type": "typo3-cms-extension",
    "description": "Generic course catalog for the education sector. Manages courses, events, locations, and contact persons.",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Davitec GmbH, +Pluswerk Standort Dresden",
            "email": "devops@davitec.de",
            "homepage": "https://www.davitec.de"
        }
    ],
    "require": {
        "php": "^8.2",
        "typo3/cms-core": "^12.4 || ^13.4",
        "typo3/cms-extbase": "^12.4 || ^13.4",
        "typo3/cms-fluid": "^12.4 || ^13.4",
        "typo3/cms-frontend": "^12.4 || ^13.4"
    },
    "require-dev": {
        "typo3/testing-framework": "^8.0 || ^9.0",
        "phpunit/phpunit": "^10.5 || ^11.0"
    },
    "autoload": {
        "psr-4": {
            "Davitec\\DvEducationCourses\\": "Classes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Davitec\\DvEducationCourses\\Tests\\": "Tests/"
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "dv_education_courses"
        }
    },
    "support": {
        "docs": "https://docs.typo3.org/p/davitec/dv-education-courses/main/en-us/Index.html"
    }
}
